{
  "name": "aithru-agent",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Agent execution layer for the Aithru ecosystem.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --workspace-concurrency=1 build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "pnpm -r --filter './packages/**' test",
    "example:classify": "pnpm build && tsx examples/standalone-classify.ts",
    "example:plan-run-review": "pnpm build && tsx examples/standalone-plan-run-review.ts",
    "example:node-agent-basic": "pnpm build && NODE_OPTIONS=--conditions=development tsx examples/node-agent-basic.ts",
    "example:workflow-node-agent": "pnpm build && NODE_OPTIONS=--conditions=development tsx examples/workflow-node-agent.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@aithru/agent-core": "workspace:*",
    "@aithru/agent-model-openai-compatible": "workspace:*",
    "@aithru/agent-runtime": "workspace:*",
    "@aithru/agent-model-test": "workspace:*",
    "@aithru/node-agent": "workspace:*",
    "@aithru/node-sdk": "workspace:*",
    "@aithru/nodes-core": "workspace:*",
    "@aithru/runtime-local": "workspace:*",
    "@aithru/runtime-core": "workspace:*",
    "@aithru/spec": "workspace:*",
    "@types/node": "^25.9.1",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
